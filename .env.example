# Plantilla de variables de entorno. Copia este archivo a `.env` y ajusta los valores.
# Este es el ÚNICO archivo .env que se versiona (ver "Límites duros" en tech-stack.md).

# Credenciales del contenedor de PostgreSQL para desarrollo local (docker-compose.yml).
POSTGRES_USER="laguaira"
POSTGRES_PASSWORD="laguaira"
POSTGRES_DB="unidos_por_la_guaira"

# Cadena de conexión que usa Prisma.
# - Desarrollo: el PostgreSQL levantado por `docker compose up -d` (publicado en el
#   puerto 5435 del host para no chocar con otro Postgres que use el 5432).
# - Producción: la base de Supabase.
DATABASE_URL="postgresql://laguaira:laguaira@localhost:5432/unidos_por_la_guaira?schema=public"

# URL pública del sitio (SEO: canonical, Open Graph, sitemap). En desarrollo suele ser
# http://localhost:3000; en producción, el dominio real (p. ej. https://unidosporlaguaira.org).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secreto para firmar los JWT de sesión. Genera uno con: `openssl rand -base64 32`
# (o `npx auth secret`). Obligatorio en producción.
AUTH_SECRET="cambia-esto-por-un-secreto-aleatorio"

# ── Supabase Storage (feature 031: imágenes y documentación de solicitudes) ──
# Almacenamiento de los archivos que sube el solicitante. El binario vive en un
# bucket PRIVADO de Supabase; la app guarda solo la ruta y sirve por URL firmada.
# - SUPABASE_URL: URL del proyecto (https://<ref>.supabase.co). Es la misma que
#   Supabase entrega como NEXT_PUBLIC_SUPABASE_URL; el código acepta cualquiera de
#   las dos, así que puedes dejar solo NEXT_PUBLIC_SUPABASE_URL si ya la tienes.
# - SUPABASE_SERVICE_ROLE_KEY: la clave SECRETA (service_role, o la "secret key"
#   sb_secret_… del nuevo formato). SOLO SERVIDOR, nunca NEXT_PUBLIC_. NO es la
#   "publishable"/anon (esa es pública y no sirve para firmar subidas al bucket
#   privado). La subida usa URLs firmadas de un solo uso emitidas en el servidor.
# - SUPABASE_STORAGE_BUCKET: nombre del bucket privado (créalo, p. ej. "solicitudes").
# En desarrollo local basta con apuntar a un proyecto Supabase real; sin estas
# variables, subir archivos falla pero el resto de la solicitud funciona.
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="cambia-esto-por-la-clave-secreta-service-role"
SUPABASE_STORAGE_BUCKET="solicitudes"

# ── Seed del SUPERADMIN inicial (`pnpm db:seed`) ────────────────────────────
# Raíz de confianza (feature 015): no se crea desde el registro público; se
# siembra con estas credenciales y es la única autoridad que aprueba cuentas
# ADMIN. Los ADMIN ya NO se siembran: se registran públicamente (quedan en
# PENDIENTE hasta que el SUPERADMIN los aprueba). No subir valores reales al repo.
SUPERADMIN_EMAIL="superadmin@unidosporlaguaira.org"
SUPERADMIN_PASSWORD="cambia-esta-contraseña"
SUPERADMIN_NOMBRE="Superadministrador"

# ── Seed de usuarios de prueba (opcional, solo desarrollo) ─────────────────
# Si defines estos, el seed crea un COLABORADOR y un SOLICITANTE listos para
# probar 006 (aportes) y 007 (solicitudes) sin registrarlos por la UI. En
# producción déjalos vacíos y el seed los omite.
COLABORADOR_EMAIL=""
COLABORADOR_PASSWORD=""
COLABORADOR_NOMBRE="Colaborador Prueba"

SOLICITANTE_EMAIL=""
SOLICITANTE_PASSWORD=""
SOLICITANTE_NOMBRE="Solicitante Prueba"
