# Plantilla de variables de entorno. Copia este archivo a `.env` y ajusta los valores.
# Este es el ÚNICO archivo .env que se versiona (ver "Límites duros" en tech-stack.md).

# Credenciales del contenedor de PostgreSQL para desarrollo local (docker-compose.yml).
POSTGRES_USER="guayana"
POSTGRES_PASSWORD="guayana"
POSTGRES_DB="unidos_por_guayana"

# Cadena de conexión que usa Prisma.
# - Desarrollo: el PostgreSQL levantado por `docker compose up -d`.
# - Producción: la base de Supabase.
DATABASE_URL="postgresql://guayana:guayana@localhost:5432/unidos_por_guayana?schema=public"
