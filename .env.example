# Plantilla de variables de entorno. Copia este archivo a `.env` y ajusta los valores.
# Este es el ÚNICO archivo .env que se versiona (ver "Límites duros" en tech-stack.md).

# Credenciales del contenedor de PostgreSQL para desarrollo local (docker-compose.yml).
POSTGRES_USER="guayana"
POSTGRES_PASSWORD="guayana"
POSTGRES_DB="unidos_por_guayana"

# Cadena de conexión que usa Prisma.
# - Desarrollo: el PostgreSQL levantado por `docker compose up -d` (publicado en el
#   puerto 5435 del host para no chocar con otro Postgres que use el 5432).
# - Producción: la base de Supabase.
DATABASE_URL="postgresql://guayana:guayana@localhost:5435/unidos_por_guayana?schema=public"

# URL pública del sitio (SEO: canonical, Open Graph, sitemap). En desarrollo suele ser
# http://localhost:3000; en producción, el dominio real (p. ej. https://unidosporguayana.org).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secreto para firmar los JWT de sesión. Genera uno con: `openssl rand -base64 32`
# (o `npx auth secret`). Obligatorio en producción.
AUTH_SECRET="cambia-esto-por-un-secreto-aleatorio"

# ── Seed del ADMIN inicial (`npm run db:seed`) ──────────────────────────────
# El primer ADMIN no puede crearse desde el registro público; se siembra con
# estas credenciales. No subir valores reales al repo.
ADMIN_EMAIL="admin@unidosporguayana.org"
ADMIN_PASSWORD="cambia-esta-contraseña"
ADMIN_NOMBRE="Administrador"
