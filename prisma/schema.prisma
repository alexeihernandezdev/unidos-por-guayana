// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Rol del usuario. Controla los permisos en toda la plataforma (ver
// constitution/tech-stack.md). `SUPERADMIN` es la raíz de confianza: no se
// auto-registra, se siembra con `pnpm db:seed` y es la única autoridad que
// aprueba cuentas `ADMIN`. `ADMIN` sí es de registro público, pero la cuenta
// nace en `estadoVerificacion = PENDIENTE` y no opera hasta que el `SUPERADMIN`
// la aprueba (ver feature 015, que enmienda la 002).
enum Rol {
  SUPERADMIN
  ADMIN
  COLABORADOR
  SOLICITANTE
}

// Estado de verificación del usuario. Nace en `PENDIENTE`; su gestión real
// (aprobar/rechazar colaboradores y solicitantes) es la feature 013. Se modela
// desde ya para no re-migrar más adelante.
enum EstadoVerificacion {
  PENDIENTE
  VERIFICADO
  RECHAZADO
}

// Persona registrada en la plataforma. La contraseña se guarda siempre hasheada
// (nunca en claro). La autenticación es por credenciales (email + contraseña)
// con Auth.js v5 y sesión JWT.
model Usuario {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  nombre             String
  rol                Rol
  estadoVerificacion EstadoVerificacion @default(PENDIENTE)
  // Datos de contacto y ubicación (feature 017, enmendada por 020). Obligatorios
  // en el flujo para COLABORADOR/SOLICITANTE; opcionales en base para no romper
  // cuentas creadas antes (el guard las redirige a `/completar-perfil`). El ADMIN
  // guarda su ubicación en `PerfilAdmin` (016); aquí solo comparte el flag WhatsApp.
  cedula             String?            @unique
  telefono           String?
  telefonoEsWhatsApp Boolean            @default(false)
  estadoId           String?
  municipioId        String?
  estado             Estado?            @relation(fields: [estadoId], references: [id], onDelete: Restrict)
  municipio          Municipio?         @relation(fields: [municipioId], references: [id], onDelete: Restrict)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Aportes que este usuario ha registrado como colaborador (feature 006).
  aportes Aporte[]
  // Relación inversa: solicitudes de ayuda creadas por el solicitante (feature 007).
  solicitudes Solicitud[]
  // Relación inversa: recursos que este usuario ha propuesto al catálogo (feature 019).
  recursosPropuestos Recurso[] @relation("RecursosPropuestos")
  // Perfil ampliado de centro de acopio (solo cuentas ADMIN, feature 016). La
  // regla "solo ADMIN" la asegura la aplicación; Prisma no restringe por enum.
  perfilAdmin PerfilAdmin?
  // Puntos de acopio que gestiona este ADMIN (feature 016 declara el lado admin;
  // el modelo completo lo crea la feature 011).
  puntosAcopio PuntoAcopio[]

  @@index([estadoId])
  @@index([municipioId])
  @@map("usuarios")
}

// Tipo de documento de identidad de un centro de acopio (feature 016). `JURIDICO`
// para organizaciones, `NATURAL` para personas. Sus valores coinciden con el enum
// de dominio para mapear sin casts.
enum TipoDocumento {
  JURIDICO
  NATURAL
}

// PerfilAdmin: extensión uno a uno de una cuenta `ADMIN` que la identifica como
// centro de acopio dentro de la red (feature 016). Se captura en el registro
// público del admin (feature 015) y el `SUPERADMIN` lo revisa al aprobar. La
// unicidad por `usuarioId` garantiza un solo perfil por cuenta. Se borra en
// cascada con el usuario.
model PerfilAdmin {
  id                 String        @id @default(cuid())
  usuarioId          String        @unique
  usuario            Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  nombreCuenta       String
  // Ubicación por catálogo (feature 020 enmienda 016). Nullable en BD para filas
  // legacy sin match de backfill; el flujo exige ambos al crear/editar.
  estadoId           String?
  municipioId        String?
  estado             Estado?       @relation(fields: [estadoId], references: [id], onDelete: Restrict)
  municipio          Municipio?    @relation(fields: [municipioId], references: [id], onDelete: Restrict)
  telefono           String
  // Flag WhatsApp del teléfono del centro de acopio (feature 017 amplía 016).
  telefonoEsWhatsApp Boolean       @default(false)
  correo             String
  tipoDocumento      TipoDocumento
  numeroDocumento    String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([estadoId])
  @@index([municipioId])
  @@map("perfiles_admin")
}

// Catálogo de divisiones político-territoriales de Venezuela (feature 020).
// Solo lectura en runtime: se siembra con `pnpm db:seed`. 24 entidades (23
// estados + Distrito Capital); sin Dependencias Federales ni Guayana Esequiba.
model Estado {
  id            String        @id @default(cuid())
  codigo        String        @unique
  nombre        String        @unique
  municipios    Municipio[]
  usuarios      Usuario[]
  perfilesAdmin PerfilAdmin[]

  @@map("estados")
}

model Municipio {
  id            String        @id @default(cuid())
  codigo        String?
  nombre        String
  estadoId      String
  estado        Estado        @relation(fields: [estadoId], references: [id], onDelete: Restrict)
  usuarios      Usuario[]
  perfilesAdmin PerfilAdmin[]

  @@unique([estadoId, nombre])
  @@index([estadoId])
  @@map("municipios")
}

// PuntoAcopio: centro físico de entrega perteneciente a un `ADMIN`. La feature 016
// solo declara el lado admin de la relación (`adminId`) para no re-migrar; el
// modelo completo (nombre, dirección, horarios, qué recibe) lo añade la feature
// 011. Un `PuntoAcopio` nuevo hereda por defecto `estadoId`/`municipioId` del
// `PerfilAdmin` de su admin (regla de dominio que consumirá la 011).
model PuntoAcopio {
  id        String   @id @default(cuid())
  adminId   String
  admin     Usuario  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@map("puntos_acopio")
}

// Categoría de un recurso del catálogo (ver feature 004 y constitution/tech-stack.md).
// `SUMINISTRO` (agua, alimentos, medicinas…), `TRANSPORTE` (camión, combustible…),
// `PERSONAL` (voluntarios…) y `MONETARIO` (donación en USD/Bs, recibida por fuera
// de la app). Sus valores coinciden con el enum de dominio para mapear sin casts.
enum CategoriaRecurso {
  SUMINISTRO
  TRANSPORTE
  PERSONAL
  MONETARIO
}

// Estado de aprobación del recurso (feature 019). Un `ADMIN` crea recursos ya
// `APROBADO`; un `SOLICITANTE` puede proponer nuevos recursos que nacen
// `PROPUESTO` a la espera de revisión. Solo los `APROBADO` (y `activo`) son
// seleccionables en metas y aportes. `RECHAZADO` es terminal y se conserva
// para auditoría. Backfill: los recursos existentes quedan `APROBADO`.
enum EstadoAprobacionRecurso {
  APROBADO
  PROPUESTO
  RECHAZADO
}

// Recurso del catálogo: la referencia estable contra la que se miden metas y
// aportes. `nombre` es único (se guarda tal cual con trim; la unicidad insensible
// a mayúsculas se valida en la aplicación). `unidad` es texto libre (litros, cajas,
// personas, USD…). No se borran: se archivan (`activo = false`) para no dejar metas
// ni aportes huérfanos (features 005/006).
model Recurso {
  id               String                  @id @default(cuid())
  nombre           String                  @unique
  unidad           String
  categoria        CategoriaRecurso
  descripcion      String?
  activo           Boolean                 @default(true)
  estadoAprobacion EstadoAprobacionRecurso @default(APROBADO)
  propuestoPorId   String?
  propuestoPor     Usuario?                @relation("RecursosPropuestos", fields: [propuestoPorId], references: [id])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // Relación inversa: metas de envío que apuntan a este recurso (feature 005).
  // Como los recursos se archivan (no se borran), no habrá metas huérfanas.
  metas MetaRecurso[]

  // Aportes registrados contra este recurso (feature 006).
  aportes Aporte[]
  // Relación inversa: recursos necesarios en solicitudes de ayuda (feature 007).
  recursoSolicitudes RecursoSolicitud[]

  @@index([estadoAprobacion])
  @@map("recursos")
}

// Tipo de actividad de una Ayuda (feature 018). La entidad Ayuda es la misma para
// las tres clases (envío / jornada / evento social): comparten ciclo de vida,
// metas, aportes y seguimiento. Solo cambia el vocabulario visible en la UI.
// Backfill: las Ayudas existentes se consideran `ENVIO`.
enum TipoActividad {
  ENVIO
  JORNADA
  EVENTO_SOCIAL
}

// Ciclo de vida de una Ayuda (ver feature 005 y constitution/tech-stack.md). Avanza
// en un solo sentido: RECOLECTANDO → LISTO → EN_TRANSITO → ENTREGADO. La máquina de
// estados (transiciones válidas) vive como regla pura en el dominio. Sus valores
// coinciden con el enum de dominio para mapear sin casts.
enum EstadoAyuda {
  RECOLECTANDO
  LISTO
  EN_TRANSITO
  ENTREGADO
}

// Ayuda / Envío: la entidad central de la plataforma. Un envío concreto de ayuda
// humanitaria hacia un sector, con una fecha de salida y un ciclo de vida. Define
// qué necesita y cuánto mediante sus `metas` (MetaRecurso). Solo la gestiona el
// `ADMIN`. Nace en `RECOLECTANDO`; la cabecera y las metas solo se editan mientras
// siga en ese estado (después quedan congeladas para medir el progreso).
model Ayuda {
  id            String        @id @default(cuid())
  titulo        String
  sectorDestino String
  fecha         DateTime
  estado        EstadoAyuda   @default(RECOLECTANDO)
  tipo          TipoActividad @default(ENVIO)
  descripcion   String?
  metas         MetaRecurso[]
  aportes       Aporte[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tipo])
  @@map("ayudas")
}

// MetaRecurso: puente entre `Ayuda` y `Recurso`. `cantidadObjetivo` es cuánto
// necesita el envío de ese recurso, en la unidad del recurso. Se guarda como
// `Decimal` por precisión y se convierte a `number` en el límite de infraestructura
// (el dominio trabaja con números puros). Única por (ayuda, recurso): un recurso no
// se repite en dos metas de la misma Ayuda. Se borra en cascada con su Ayuda.
model MetaRecurso {
  id               String   @id @default(cuid())
  ayudaId          String
  ayuda            Ayuda    @relation(fields: [ayudaId], references: [id], onDelete: Cascade)
  recursoId        String
  recurso          Recurso  @relation(fields: [recursoId], references: [id])
  cantidadObjetivo Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([ayudaId, recursoId])
  @@map("metas_recurso")
}

// Estado del Aporte (feature 006). `COMPROMETIDO` es la intención declarada por el
// colaborador; solo cuando el ADMIN lo marca `RECIBIDO` suma al progreso de la meta.
// Sus valores coinciden con el enum de dominio para mapear sin casts.
enum EstadoAporte {
  COMPROMETIDO
  RECIBIDO
}

// Aporte: registro con el que un COLABORADOR ofrece ayuda a una Ayuda concreta
// contra un Recurso del catálogo. Nace en `COMPROMETIDO`; el ADMIN lo marca
// `RECIBIDO` al confirmar la entrega (o el ingreso monetario externo). Solo los
// `RECIBIDO` suman al progreso de la meta correspondiente (feature 009).
// No se hace cascade desde Ayuda: una Ayuda con aportes no debería borrarse (solo
// se elimina en `RECOLECTANDO`, y quitar los aportes en ese punto es explícito).
model Aporte {
  id             String       @id @default(cuid())
  ayudaId        String
  ayuda          Ayuda        @relation(fields: [ayudaId], references: [id])
  recursoId      String
  recurso        Recurso      @relation(fields: [recursoId], references: [id])
  colaboradorId  String
  colaborador    Usuario      @relation(fields: [colaboradorId], references: [id])
  cantidad       Decimal      @db.Decimal(12, 2)
  estado         EstadoAporte @default(COMPROMETIDO)
  nota           String?
  recibidoEn     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([ayudaId])
  @@index([ayudaId, recursoId, estado])
  @@map("aportes")
}
// Urgencia de una solicitud de ayuda (feature 007). Tres niveles para priorizar sin
// paralizar al solicitante con una escala numérica.
enum UrgenciaSolicitud {
  BAJA
  MEDIA
  ALTA
}

// Ciclo de vida de una solicitud de ayuda (feature 007). Avanza desde `ABIERTA` hacia
// `ATENDIDA` o `CERRADA`; ambos son terminales y no se reabren.
enum EstadoSolicitud {
  ABIERTA
  ATENDIDA
  CERRADA
}

// Quién cerró la solicitud (feature 007). Distingue cancelación del solicitante de
// cierre administrativo por el ADMIN.
enum CerradaPor {
  SOLICITANTE
  ADMIN
}

// Solicitud de ayuda: petición formal de un SOLICITANTE para un sector concreto,
// indicando urgencia, descripción y recursos necesarios del catálogo. Nace en `ABIERTA`.
// El ADMIN la marca `ATENDIDA` o `CERRADA`; el solicitante puede cancelarla mientras
// esté abierta.
model Solicitud {
  id            String            @id @default(cuid())
  sector        String
  urgencia      UrgenciaSolicitud
  descripcion   String
  estado        EstadoSolicitud   @default(ABIERTA)
  cerradaPor    CerradaPor?
  solicitanteId String
  solicitante   Usuario           @relation(fields: [solicitanteId], references: [id])
  recursos      RecursoSolicitud[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([estado])
  @@index([sector])
  @@map("solicitudes")
}

// RecursoSolicitud: puente entre `Solicitud` y `Recurso`. `cantidadEstimada` es
// opcional (el solicitante puede no saber cuánto necesita). Se guarda como `Decimal`
// por precisión y se convierte a `number` en el límite de infraestructura.
model RecursoSolicitud {
  id                String    @id @default(cuid())
  solicitudId       String
  solicitud         Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  recursoId         String
  recurso           Recurso   @relation(fields: [recursoId], references: [id])
  cantidadEstimada  Decimal?  @db.Decimal(12, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([solicitudId, recursoId])
  @@map("recursos_solicitud")
}
