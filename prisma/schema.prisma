// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Rol del usuario. Controla los permisos en toda la plataforma (ver
// constitution/tech-stack.md). `SUPERADMIN` es la raĂ­z de confianza: no se
// auto-registra, se siembra con `pnpm db:seed` y es la Ăşnica autoridad que
// aprueba cuentas `ADMIN`. `ADMIN` sĂ­ es de registro pĂşblico, pero la cuenta
// nace en `estadoVerificacion = PENDIENTE` y no opera hasta que el `SUPERADMIN`
// la aprueba (ver feature 015, que enmienda la 002).
enum Rol {
  SUPERADMIN
  ADMIN
  AUDITOR
  COLABORADOR
  SOLICITANTE
}

// Estado de verificaciĂłn del usuario. Nace en `PENDIENTE`; su gestiĂłn real
// (aprobar/rechazar colaboradores y solicitantes) es la feature 013. Se modela
// desde ya para no re-migrar mĂˇs adelante.
enum EstadoVerificacion {
  PENDIENTE
  VERIFICADO
  RECHAZADO
}

// Persona registrada en la plataforma. La contraseĂ±a se guarda siempre hasheada
// (nunca en claro). La autenticaciĂłn es por credenciales (email + contraseĂ±a)
// con Auth.js v5 y sesiĂłn JWT.
model Usuario {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  nombre             String
  rol                Rol
  estadoVerificacion EstadoVerificacion @default(PENDIENTE)
  // Datos de contacto y ubicaciĂłn (feature 017; ubicaciĂłn por catĂˇlogo desde la
  // 020). Obligatorios en el flujo para COLABORADOR/SOLICITANTE; opcionales en
  // base para no romper cuentas creadas antes (el guard las redirige a
  // `/completar-perfil`). El ADMIN guarda sus datos en `PerfilAdmin` (016); aquĂ­
  // solo comparte el flag WhatsApp. `estadoId`/`municipioId` referencian el
  // catĂˇlogo de ubicaciĂłn (020, sustituye a los antiguos `estado`/`parroquia` de
  // texto libre).
  cedula             String?            @unique
  telefono           String?
  telefonoEsWhatsApp Boolean            @default(false)
  estadoId           String?
  estadoUbicacion    Estado?            @relation(fields: [estadoId], references: [id])
  municipioId        String?
  municipioUbicacion Municipio?         @relation(fields: [municipioId], references: [id])
  // CategorĂ­as de recurso que un COLABORADOR declara poder aportar (feature 025).
  // Capacidad de la persona (no varĂ­a por centro). Obligatoria (>= 1) para
  // COLABORADOR; la regla la asegura la aplicaciĂłn (una columna array no lo hace).
  categoriasAporte   CategoriaRecurso[] @default([])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Aportes que este usuario ha registrado como colaborador (feature 006).
  aportes            Aporte[]      @relation("AportesColaborador")
  aportesRegistrados Aporte[]      @relation("AportesRegistrados")
  // RelaciĂłn inversa: solicitudes de ayuda creadas por el solicitante (feature 007).
  solicitudes        Solicitud[]
  // RelaciĂłn inversa: recursos que este usuario ha propuesto al catĂˇlogo (feature 019).
  recursosPropuestos Recurso[]     @relation("RecursosPropuestos")
  // Perfil ampliado de centro de acopio (solo cuentas ADMIN, feature 016). La
  // regla "solo ADMIN" la asegura la aplicaciĂłn; Prisma no restringe por enum.
  perfilAdmin        PerfilAdmin?
  // Puntos de acopio que gestiona este ADMIN (feature 016 declara el lado admin;
  // el modelo completo lo crea la feature 011).
  puntosAcopio       PuntoAcopio[]
  // Actividades que este ADMIN creĂł y gestiona (feature 022; entidad renombrada
  // de `Ayuda` a `Actividad` en la feature 024).
  actividades        Actividad[]
  // Afiliaciones a centros de acopio (feature 025): las que este usuario tiene
  // como COLABORADOR (`afiliaciones`) y las de su red como ADMIN (`red`).
  afiliaciones       Afiliacion[]  @relation("ColaboradorAfiliaciones")
  red                Afiliacion[]  @relation("AdminRed")
  testimonios        Testimonio[]  @relation("TestimoniosAutor")
  testimoniosModerados Testimonio[] @relation("TestimoniosModerador")
  solicitudesEnAuditoria Solicitud[] @relation("AuditorActualSolicitud")
  eventosAuditoria EventoAuditoriaSolicitud[] @relation("ActorEventoAuditoria")

  @@index([estadoId])
  @@index([municipioId])
  @@map("usuarios")
}

// Afiliacion (feature 025): vĂ­nculo unilateral entre un COLABORADOR y un ADMIN
// (centro de acopio) al que elige unirse. Existir la fila = afiliado; remover =
// borrar la fila (re-afiliarse permitido, sin estado de bloqueo). Puramente
// informativa: no restringe a quĂ© Actividad puede aportar el colaborador. Se borra
// en cascada con cualquiera de los dos usuarios.
model Afiliacion {
  id            String   @id @default(cuid())
  colaboradorId String
  colaborador   Usuario  @relation("ColaboradorAfiliaciones", fields: [colaboradorId], references: [id], onDelete: Cascade)
  adminId       String
  admin         Usuario  @relation("AdminRed", fields: [adminId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([colaboradorId, adminId])
  @@index([colaboradorId])
  @@index([adminId])
  @@map("afiliaciones")
}

// Tipo de documento de identidad de un centro de acopio (feature 016). `JURIDICO`
// para organizaciones, `NATURAL` para personas. Sus valores coinciden con el enum
// de dominio para mapear sin casts.
enum TipoDocumento {
  JURIDICO
  NATURAL
}

// PerfilAdmin: extensiĂłn uno a uno de una cuenta `ADMIN` que la identifica como
// centro de acopio dentro de la red (feature 016). Se captura en el registro
// pĂşblico del admin (feature 015) y el `SUPERADMIN` lo revisa al aprobar. La
// unicidad por `usuarioId` garantiza un solo perfil por cuenta. Se borra en
// cascada con el usuario.
model PerfilAdmin {
  id                 String        @id @default(cuid())
  usuarioId          String        @unique
  usuario            Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  nombreCuenta       String
  // UbicaciĂłn por catĂˇlogo (feature 020, sustituye a los antiguos `estado`/
  // `parroquia` de texto libre). Nullable en base para no bloquear la migraciĂłn;
  // el flujo de registro/ediciĂłn del admin los exige.
  estadoId           String?
  estadoUbicacion    Estado?       @relation(fields: [estadoId], references: [id])
  municipioId        String?
  municipioUbicacion Municipio?    @relation(fields: [municipioId], references: [id])
  telefono           String
  // Flag WhatsApp del telĂ©fono del centro de acopio (feature 017 amplĂ­a 016).
  telefonoEsWhatsApp Boolean       @default(false)
  correo             String
  tipoDocumento      TipoDocumento
  numeroDocumento    String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([estadoId])
  @@index([municipioId])
  @@map("perfiles_admin")
}

// PuntoAcopio: ubicaciĂłn fĂ­sica perteneciente a un `ADMIN` (feature 011). Un
// admin puede tener 0..N puntos. El punto NO declara "quĂ© recibe": los aportes
// van a Ayudas (envĂ­os/jornadas/eventos), no a puntos. La ubicaciĂłn se captura
// como coordenadas `latitud`/`longitud` (Leaflet en la UI) mĂˇs `estadoId`/
// `municipioId` del catĂˇlogo (feature 020) para filtrar y agrupar. Al crear,
// `estadoId`/`municipioId` heredan del `PerfilAdmin` como valor efectivo (se
// copian, no se referencian vivos). `referencia` es texto orientativo para el
// que va a llegar (el mapa da la posiciĂłn exacta). Soft-archive con `activo`.
model PuntoAcopio {
  id                 String    @id @default(cuid())
  adminId            String
  admin              Usuario   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  nombre             String
  referencia         String
  latitud            Decimal   @db.Decimal(9, 6)
  longitud           Decimal   @db.Decimal(9, 6)
  horarios           String
  telefono           String
  telefonoEsWhatsApp Boolean   @default(true)
  correo             String?
  estadoId           String
  estadoUbicacion    Estado    @relation(fields: [estadoId], references: [id])
  municipioId        String
  municipioUbicacion Municipio @relation(fields: [municipioId], references: [id])
  activo             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Actividades que se reciben o se realizan en este punto. Desde la feature 026 la
  // relaciĂłn es muchos a muchos a travĂ©s de la tabla puente `ActividadPuntoAcopio`
  // (una actividad puede asignar varios puntos). Cascada al archivar/borrar el punto.
  actividades ActividadPuntoAcopio[]

  @@unique([adminId, nombre])
  @@index([adminId])
  @@index([estadoId])
  @@index([municipioId])
  @@map("puntos_acopio")
}

// CatĂˇlogo de ubicaciĂłn (feature 020). `Estado` y `Municipio` modelan la divisiĂłn
// polĂ­tico-territorial de Venezuela (24 entidades federales y ~335 municipios) y
// se siembran con `pnpm db:seed`. `codigo` es la clave natural estable (ISO
// 3166-2:VE para el estado, `<codigoEstado>-<nn>` para el municipio) que hace la
// siembra idempotente (upsert por `codigo`). Es de solo lectura para la app: no
// hay CRUD; se mantiene vĂ­a seed. `Usuario` y `PerfilAdmin` referencian este
// catĂˇlogo por `estadoId`/`municipioId` en vez de guardar texto libre.
model Estado {
  id              String   @id @default(cuid())
  codigo          String   @unique
  nombre          String
  // Coordenadas de la capital del estado (feature 011): centro inicial del mapa
  // al crear un punto de acopio. Nullable en base (el seed las llena; upsert por
  // `codigo`); el consumidor cae a un centro por defecto de Venezuela si faltan.
  latitudCapital  Decimal? @db.Decimal(9, 6)
  longitudCapital Decimal? @db.Decimal(9, 6)

  municipios    Municipio[]
  usuarios      Usuario[]
  perfilesAdmin PerfilAdmin[]
  puntosAcopio  PuntoAcopio[]

  @@map("estados")
}

// Municipio del catĂˇlogo. Cuelga de un `Estado` (relaciĂłn obligatoria); el
// desplegable de municipio se filtra por el `estadoId` elegido. `codigo` Ăşnico
// global permite corregir nombres sin romper las FKs que lo referencian.
model Municipio {
  id       String @id @default(cuid())
  codigo   String @unique
  nombre   String
  estadoId String
  estado   Estado @relation(fields: [estadoId], references: [id], onDelete: Cascade)

  usuarios      Usuario[]
  perfilesAdmin PerfilAdmin[]
  puntosAcopio  PuntoAcopio[]

  @@index([estadoId])
  @@map("municipios")
}

// CategorĂ­a de un recurso del catĂˇlogo (ver feature 004 y constitution/tech-stack.md).
// `SUMINISTRO` (agua, alimentos, medicinasâ€¦), `TRANSPORTE` (camiĂłn, combustibleâ€¦),
// `PERSONAL` (voluntariosâ€¦) y `MONETARIO` (donaciĂłn en USD/Bs, recibida por fuera
// de la app). Sus valores coinciden con el enum de dominio para mapear sin casts.
enum CategoriaRecurso {
  SUMINISTRO
  TRANSPORTE
  PERSONAL
  MONETARIO
}

// Estado de aprobaciĂłn del recurso (feature 019). Un `ADMIN` crea recursos ya
// `APROBADO`; un `SOLICITANTE` puede proponer nuevos recursos que nacen
// `PROPUESTO` a la espera de revisiĂłn. Solo los `APROBADO` (y `activo`) son
// seleccionables en metas y aportes. `RECHAZADO` es terminal y se conserva
// para auditorĂ­a. Backfill: los recursos existentes quedan `APROBADO`.
enum EstadoAprobacionRecurso {
  APROBADO
  PROPUESTO
  RECHAZADO
}

// Recurso del catĂˇlogo: la referencia estable contra la que se miden metas y
// aportes. `nombre` es Ăşnico (se guarda tal cual con trim; la unicidad insensible
// a mayĂşsculas se valida en la aplicaciĂłn). `unidad` es texto libre (litros, cajas,
// personas, USDâ€¦). No se borran: se archivan (`activo = false`) para no dejar metas
// ni aportes huĂ©rfanos (features 005/006).
model Recurso {
  id               String                  @id @default(cuid())
  nombre           String                  @unique
  unidad           String
  categoria        CategoriaRecurso
  descripcion      String?
  activo           Boolean                 @default(true)
  estadoAprobacion EstadoAprobacionRecurso @default(APROBADO)
  propuestoPorId   String?
  propuestoPor     Usuario?                @relation("RecursosPropuestos", fields: [propuestoPorId], references: [id])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // RelaciĂłn inversa: metas de envĂ­o que apuntan a este recurso (feature 005).
  // Como los recursos se archivan (no se borran), no habrĂˇ metas huĂ©rfanas.
  metas MetaRecurso[]

  // Aportes registrados contra este recurso (feature 006).
  aportes            Aporte[]
  // RelaciĂłn inversa: recursos necesarios en solicitudes de ayuda (feature 007).
  recursoSolicitudes RecursoSolicitud[]

  @@index([estadoAprobacion])
  @@map("recursos")
}

// Tipo de actividad (feature 018). La entidad Actividad es la misma para las tres
// clases (envĂ­o / jornada / evento social): comparten metas, aportes y seguimiento.
// Cambia el vocabulario visible en la UI y, desde la feature 024, la secuencia de
// estados vĂˇlida (ver `EstadoActividad`). Backfill: las actividades existentes se
// consideran `ENVIO`.
enum TipoActividad {
  ENVIO
  JORNADA
  EVENTO_SOCIAL
}

// Ciclo de vida de una Actividad (features 005 y 024). Un Ăşnico enum en base con la
// uniĂłn de los estados de las dos secuencias; quĂ© transiciones son vĂˇlidas lo module
// el dominio segĂşn el `tipo` (regla pura, `maquinaEstados.ts`):
//   ENVIO:               RECOLECTANDO â†’ LISTO â†’ EN_TRANSITO â†’ ENTREGADO
//   JORNADA/EVENTO_SOCIAL: RECOLECTANDO â†’ LISTA â†’ EN_CURSO â†’ REALIZADA
// `RECOLECTANDO` es el estado inicial compartido. Sus valores coinciden con los del
// dominio para mapear sin casts.
enum EstadoActividad {
  RECOLECTANDO
  LISTO
  EN_TRANSITO
  ENTREGADO
  LISTA
  EN_CURSO
  REALIZADA
}

// Actividad (antes `Ayuda`, renombrada en la feature 024): la entidad central de la
// plataforma. SegĂşn su `tipo` es un envĂ­o de ayuda humanitaria, una jornada o un
// evento social hacia un sector, con una fecha de inicio y un ciclo de vida. Define
// quĂ© necesita y cuĂˇnto mediante sus `metas` (MetaRecurso). Solo la gestiona el
// `ADMIN`. Nace en `RECOLECTANDO`; la cabecera y las metas solo se editan mientras
// siga en ese estado (despuĂ©s quedan congeladas para medir el progreso).
model Actividad {
  id            String                 @id @default(cuid())
  // DueĂ±o: el ADMIN que creĂł la actividad (feature 022). Inmutable tras el alta.
  adminId       String
  admin         Usuario                @relation(fields: [adminId], references: [id])
  titulo        String
  sectorDestino String
  // `fecha` es el inicio; `horaFin` (feature 024) es el fin opcional de una JORNADA
  // o EVENTO_SOCIAL (p. ej. "de 9:00 a 13:00"). Un ENVIO no la usa.
  fecha         DateTime
  horaFin       DateTime?
  estado        EstadoActividad        @default(RECOLECTANDO)
  tipo          TipoActividad          @default(ENVIO)
  descripcion   String?
  // Puntos de acopio del mismo ADMIN dueĂ±o donde se recibe el aporte o se realiza la
  // actividad. Desde la feature 026 son varios (0..N) a travĂ©s de la tabla puente
  // `ActividadPuntoAcopio` (antes era un `puntoAcopioId` Ăşnico opcional de la 024).
  puntosAcopio  ActividadPuntoAcopio[]
  metas         MetaRecurso[]
  aportes       Aporte[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([adminId])
  @@index([tipo])
  @@index([estado])
  @@index([fecha])
  @@map("actividades")
}

// Puente Actividad <-> PuntoAcopio (feature 026): a quĂ© centros de acopio del ADMIN
// dueĂ±o se asigna una actividad, para que el colaborador sepa dĂłnde entregar. Sin
// estado (existir la fila = asignado). Ăšnica por (actividad, punto); se borra en
// cascada con cualquiera de los dos lados.
model ActividadPuntoAcopio {
  id            String      @id @default(cuid())
  actividadId   String
  actividad     Actividad   @relation(fields: [actividadId], references: [id], onDelete: Cascade)
  puntoAcopioId String
  puntoAcopio   PuntoAcopio @relation(fields: [puntoAcopioId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([actividadId, puntoAcopioId])
  @@index([actividadId])
  @@index([puntoAcopioId])
  @@map("actividad_punto_acopio")
}

// MetaRecurso: puente entre `Actividad` y `Recurso`. `cantidadObjetivo` es cuĂˇnto
// necesita la actividad de ese recurso, en la unidad del recurso. Se guarda como
// `Decimal` por precisiĂłn y se convierte a `number` en el lĂ­mite de infraestructura
// (el dominio trabaja con nĂşmeros puros). Ăšnica por (actividad, recurso): un recurso
// no se repite en dos metas de la misma Actividad. Se borra en cascada con su Actividad.
model MetaRecurso {
  id               String              @id @default(cuid())
  actividadId      String
  actividad        Actividad           @relation(fields: [actividadId], references: [id], onDelete: Cascade)
  recursoId        String
  recurso          Recurso             @relation(fields: [recursoId], references: [id])
  cantidadObjetivo Decimal             @db.Decimal(12, 2)
  atenciones       AtencionNecesidad[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([actividadId, recursoId])
  @@map("metas_recurso")
}

// Estado del Aporte (feature 006). `COMPROMETIDO` es la intenciĂłn declarada por el
// colaborador; solo cuando el ADMIN lo marca `RECIBIDO` suma al progreso de la meta.
// Sus valores coinciden con el enum de dominio para mapear sin casts.
enum TipoMedioDonacion {
  CUENTA_BANCARIA
  PAGO_MOVIL
  PAYPAL
  ZELLE
  BINANCE
  EFECTIVO
  OTRO
}

model MedioDonacion {
  id        String            @id @default(cuid())
  tipo      TipoMedioDonacion
  titular   String
  moneda    String
  datos     String
  nota      String?
  orden     Int               @default(0)
  activo    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  aportes   Aporte[]

  @@index([activo, orden])
  @@map("medios_donacion")
}

enum EstadoAporte {
  COMPROMETIDO
  RECIBIDO
}

// Aporte: registro con el que un COLABORADOR ofrece ayuda a una Actividad concreta
// contra un Recurso del catĂˇlogo. Nace en `COMPROMETIDO`; el ADMIN lo marca
// `RECIBIDO` al confirmar la entrega (o el ingreso monetario externo). Solo los
// `RECIBIDO` suman al progreso de la meta correspondiente (feature 009).
// No se hace cascade desde Actividad: una Actividad con aportes no deberĂ­a borrarse
// (solo se elimina en `RECOLECTANDO`, y quitar los aportes ahĂ­ es explĂ­cito).
model Aporte {
  id              String         @id @default(cuid())
  actividadId     String?
  actividad       Actividad?     @relation(fields: [actividadId], references: [id])
  recursoId       String
  recurso         Recurso        @relation(fields: [recursoId], references: [id])
  colaboradorId   String?
  colaborador     Usuario?       @relation("AportesColaborador", fields: [colaboradorId], references: [id])
  registradoPorId String?
  registradoPor   Usuario?       @relation("AportesRegistrados", fields: [registradoPorId], references: [id])
  medioDonacionId String?
  medioDonacion   MedioDonacion? @relation(fields: [medioDonacionId], references: [id])
  cantidad        Decimal        @db.Decimal(12, 2)
  moneda          String?
  estado          EstadoAporte   @default(COMPROMETIDO)
  // Marca de anonimato en superficies compartidas (feature 029). Cuando es `true`,
  // el registro de aportantes (023) y la transparencia (009) muestran "AnĂłnimo" en
  // vez del nombre; el ADMIN dueĂ±o conserva la identidad en su panel para verificar.
  // Una donaciĂłn directa imputada por el ADMIN (sin colaborador) nace en `true`.
  esAnonimo       Boolean        @default(false)
  nota            String?
  referencia      String?
  recibidoEn      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([actividadId])
  @@index([actividadId, recursoId, estado])
  @@index([medioDonacionId])
  @@map("aportes")
}

// Urgencia de una solicitud de ayuda (feature 007). Tres niveles para priorizar sin
// paralizar al solicitante con una escala numĂ©rica.
enum UrgenciaSolicitud {
  BAJA
  MEDIA
  ALTA
}

// Ciclo de vida de una solicitud de ayuda (feature 007). Avanza desde `ABIERTA` hacia
// `ATENDIDA` o `CERRADA`; ambos son terminales y no se reabren.
enum EstadoSolicitud {
  ABIERTA
  ATENDIDA
  CERRADA
}

// Estado de validaciĂłn externa. Es independiente del ciclo operativo de la
// solicitud: una peticiĂłn puede seguir ABIERTA, pero no puede atenderse hasta
// que un AUDITOR la marque como VERIFICADA.
enum EstadoVerificacionSolicitud {
  PENDIENTE
  EN_REVISION
  REQUIERE_INFORMACION
  VERIFICADA
  NO_VERIFICADA
}

enum TipoEventoAuditoriaSolicitud {
  CREADA
  TOMADA
  LIBERADA
  DICTAMEN
  REENVIADA
}

// QuiĂ©n cerrĂł la solicitud (feature 007). Distingue cancelaciĂłn del solicitante de
// cierre administrativo por el ADMIN.
enum CerradaPor {
  SOLICITANTE
  ADMIN
}

// Solicitud de ayuda: peticiĂłn formal de un SOLICITANTE para un sector concreto,
// indicando urgencia, descripciĂłn y recursos necesarios del catĂˇlogo. Nace en `ABIERTA`.
// El ADMIN la marca `ATENDIDA` o `CERRADA`; el solicitante puede cancelarla mientras
// estĂ© abierta.
model Solicitud {
  id            String             @id @default(cuid())
  sector        String
  urgencia      UrgenciaSolicitud
  descripcion   String
  estado        EstadoSolicitud    @default(ABIERTA)
  cerradaPor    CerradaPor?
  solicitanteId String
  solicitante   Usuario            @relation(fields: [solicitanteId], references: [id])
  estadoVerificacion EstadoVerificacionSolicitud @default(PENDIENTE)
  auditorActualId String?
  auditorActual Usuario? @relation("AuditorActualSolicitud", fields: [auditorActualId], references: [id], onDelete: SetNull)
  cicloAuditoria Int @default(1)
  eventosAuditoria EventoAuditoriaSolicitud[]
  recursos      RecursoSolicitud[]
  archivos      ArchivoSolicitud[]
  testimonios   Testimonio[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([estado])
  @@index([estadoVerificacion, createdAt])
  @@index([auditorActualId])
  @@index([sector])
  @@map("solicitudes")
}

// BitĂˇcora inmutable de la auditorĂ­a. Los eventos de dictamen contienen el
// respaldo de la comprobaciĂłn externa; las tomas, liberaciones y reenvĂ­os
// permiten reconstruir el flujo completo sin sobrescribir decisiones previas.
model EventoAuditoriaSolicitud {
  id                  String                       @id @default(cuid())
  solicitudId         String
  solicitud           Solicitud                    @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  actorId              String
  actor                Usuario                      @relation("ActorEventoAuditoria", fields: [actorId], references: [id])
  tipo                 TipoEventoAuditoriaSolicitud
  estadoResultante     EstadoVerificacionSolicitud
  ciclo                Int
  metodo               String?
  notaInterna          String?
  explicacionPublica   String?
  referenciaExterna   String?
  createdAt            DateTime                     @default(now())

  @@index([solicitudId, createdAt])
  @@index([actorId, createdAt])
  @@map("eventos_auditoria_solicitud")
}

enum EstadoTestimonio {
  PENDIENTE
  APROBADO
  RECHAZADO
  OCULTO
}

// Relato enviado por un colaborador o solicitante. La publicaciĂłn siempre pasa
// por moderaciĂłn de un ADMIN. La foto es un placeholder visual en esta versiĂłn.
model Testimonio {
  id                String            @id @default(cuid())
  autorId           String
  autor             Usuario           @relation("TestimoniosAutor", fields: [autorId], references: [id], onDelete: Cascade)
  solicitudId       String?
  solicitud         Solicitud?         @relation(fields: [solicitudId], references: [id], onDelete: SetNull)
  titulo            String
  contenido         String
  estado            EstadoTestimonio  @default(PENDIENTE)
  motivoRechazo     String?
  destacado         Boolean           @default(false)
  moderadoPorId     String?
  moderadoPor       Usuario?          @relation("TestimoniosModerador", fields: [moderadoPorId], references: [id], onDelete: SetNull)
  moderadoEn        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([autorId])
  @@index([solicitudId])
  @@index([estado, createdAt])
  @@index([estado, destacado])
  @@map("testimonios")
}

// Rol de un archivo dentro de una solicitud (feature 031). `PRINCIPAL` es la imagen de
// portada (mĂˇx 1 por solicitud, garantizado por Ă­ndice Ăşnico parcial en la migraciĂłn);
// `ADJUNTO` es documentaciĂłn de apoyo (imĂˇgenes, PDF o doc/docx), hasta 10 por solicitud.
enum TipoArchivoSolicitud {
  PRINCIPAL
  ADJUNTO
}

// ArchivoSolicitud: imagen principal o documento adjunto de una `Solicitud` (feature 031).
// El binario vive en Supabase Storage (bucket privado); aquĂ­ solo se guardan los metadatos
// y la ruta (`path`) del objeto. Se sirve mediante URLs firmadas de lectura de corta vida.
// Cascada: al borrar la solicitud desaparecen sus filas (los objetos en Storage se borran
// en el flujo de eliminaciĂłn de la solicitud).
model ArchivoSolicitud {
  id             String               @id @default(cuid())
  solicitudId    String
  solicitud      Solicitud            @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  tipo           TipoArchivoSolicitud
  path           String
  nombreOriginal String
  contentType    String
  tamanoBytes    Int
  createdAt      DateTime             @default(now())

  @@index([solicitudId])
  @@map("archivos_solicitud")
}

// RecursoSolicitud: puente entre `Solicitud` y `Recurso`. `cantidadEstimada` es
// opcional (el solicitante puede no saber cuĂˇnto necesita). Se guarda como `Decimal`
// por precisiĂłn y se convierte a `number` en el lĂ­mite de infraestructura.
model RecursoSolicitud {
  id               String             @id @default(cuid())
  solicitudId      String
  solicitud        Solicitud          @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  recursoId        String
  recurso          Recurso            @relation(fields: [recursoId], references: [id])
  cantidadEstimada Decimal?           @db.Decimal(12, 2)
  atencion         AtencionNecesidad?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([solicitudId, recursoId])
  @@map("recursos_solicitud")
}

// AtencionNecesidad: puente explĂ­cito entre una necesidad concreta (`RecursoSolicitud`)
// y la meta de la actividad que la atiende (`MetaRecurso`). Se crea cuando el ADMIN
// arrastra una necesidad del sidebar hacia una actividad. Una necesidad se atiende como
// mĂˇximo una vez (`recursoSolicitudId` Ăşnico); una misma meta puede atender varias
// necesidades (varias solicitudes que piden el mismo recurso). La actividad se deriva
// vĂ­a `metaRecurso.actividad`. Al crear/borrar una atenciĂłn se recalcula el estado de la
// Solicitud (ATENDIDA si todas sus necesidades tienen atenciĂłn). Cascada en ambos lados:
// desaparece si se borra la solicitud/recurso-solicitud o la meta.
model AtencionNecesidad {
  id                 String           @id @default(cuid())
  recursoSolicitudId String           @unique
  recursoSolicitud   RecursoSolicitud @relation(fields: [recursoSolicitudId], references: [id], onDelete: Cascade)
  metaRecursoId      String
  metaRecurso        MetaRecurso      @relation(fields: [metaRecursoId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@index([metaRecursoId])
  @@map("atenciones_necesidad")
}
