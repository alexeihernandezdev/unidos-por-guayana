// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Rol del usuario. Controla los permisos en toda la plataforma (ver
// constitution/tech-stack.md). `ADMIN` no es auto-registrable: se crea por seed
// o lo promueve otro `ADMIN` (ver feature 002).
enum Rol {
  ADMIN
  COLABORADOR
  SOLICITANTE
}

// Estado de verificación del usuario. Nace en `PENDIENTE`; su gestión real
// (aprobar/rechazar colaboradores y solicitantes) es la feature 013. Se modela
// desde ya para no re-migrar más adelante.
enum EstadoVerificacion {
  PENDIENTE
  VERIFICADO
  RECHAZADO
}

// Persona registrada en la plataforma. La contraseña se guarda siempre hasheada
// (nunca en claro). La autenticación es por credenciales (email + contraseña)
// con Auth.js v5 y sesión JWT.
model Usuario {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  nombre             String
  rol                Rol
  estadoVerificacion EstadoVerificacion @default(PENDIENTE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relación inversa: solicitudes de ayuda creadas por el solicitante (feature 007).
  solicitudes Solicitud[]

  @@map("usuarios")
}

// Categoría de un recurso del catálogo (ver feature 004 y constitution/tech-stack.md).
// `SUMINISTRO` (agua, alimentos, medicinas…), `TRANSPORTE` (camión, combustible…),
// `PERSONAL` (voluntarios…) y `MONETARIO` (donación en USD/Bs, recibida por fuera
// de la app). Sus valores coinciden con el enum de dominio para mapear sin casts.
enum CategoriaRecurso {
  SUMINISTRO
  TRANSPORTE
  PERSONAL
  MONETARIO
}

// Recurso del catálogo: la referencia estable contra la que se miden metas y
// aportes. `nombre` es único (se guarda tal cual con trim; la unicidad insensible
// a mayúsculas se valida en la aplicación). `unidad` es texto libre (litros, cajas,
// personas, USD…). No se borran: se archivan (`activo = false`) para no dejar metas
// ni aportes huérfanos (features 005/006).
model Recurso {
  id          String           @id @default(cuid())
  nombre      String           @unique
  unidad      String
  categoria   CategoriaRecurso
  descripcion String?
  activo      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relación inversa: metas de envío que apuntan a este recurso (feature 005).
  // Como los recursos se archivan (no se borran), no habrá metas huérfanas.
  metas MetaRecurso[]

  // Relación inversa: recursos necesarios en solicitudes de ayuda (feature 007).
  recursoSolicitudes RecursoSolicitud[]

  @@map("recursos")
}

// Ciclo de vida de una Ayuda (ver feature 005 y constitution/tech-stack.md). Avanza
// en un solo sentido: RECOLECTANDO → LISTO → EN_TRANSITO → ENTREGADO. La máquina de
// estados (transiciones válidas) vive como regla pura en el dominio. Sus valores
// coinciden con el enum de dominio para mapear sin casts.
enum EstadoAyuda {
  RECOLECTANDO
  LISTO
  EN_TRANSITO
  ENTREGADO
}

// Ayuda / Envío: la entidad central de la plataforma. Un envío concreto de ayuda
// humanitaria hacia un sector, con una fecha de salida y un ciclo de vida. Define
// qué necesita y cuánto mediante sus `metas` (MetaRecurso). Solo la gestiona el
// `ADMIN`. Nace en `RECOLECTANDO`; la cabecera y las metas solo se editan mientras
// siga en ese estado (después quedan congeladas para medir el progreso).
model Ayuda {
  id           String        @id @default(cuid())
  titulo       String
  sectorDestino String
  fecha        DateTime
  estado       EstadoAyuda   @default(RECOLECTANDO)
  descripcion  String?
  metas        MetaRecurso[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("ayudas")
}

// MetaRecurso: puente entre `Ayuda` y `Recurso`. `cantidadObjetivo` es cuánto
// necesita el envío de ese recurso, en la unidad del recurso. Se guarda como
// `Decimal` por precisión y se convierte a `number` en el límite de infraestructura
// (el dominio trabaja con números puros). Única por (ayuda, recurso): un recurso no
// se repite en dos metas de la misma Ayuda. Se borra en cascada con su Ayuda.
model MetaRecurso {
  id               String   @id @default(cuid())
  ayudaId          String
  ayuda            Ayuda    @relation(fields: [ayudaId], references: [id], onDelete: Cascade)
  recursoId        String
  recurso          Recurso  @relation(fields: [recursoId], references: [id])
  cantidadObjetivo Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([ayudaId, recursoId])
  @@map("metas_recurso")
}

// Urgencia de una solicitud de ayuda (feature 007). Tres niveles para priorizar sin
// paralizar al solicitante con una escala numérica.
enum UrgenciaSolicitud {
  BAJA
  MEDIA
  ALTA
}

// Ciclo de vida de una solicitud de ayuda (feature 007). Avanza desde `ABIERTA` hacia
// `ATENDIDA` o `CERRADA`; ambos son terminales y no se reabren.
enum EstadoSolicitud {
  ABIERTA
  ATENDIDA
  CERRADA
}

// Quién cerró la solicitud (feature 007). Distingue cancelación del solicitante de
// cierre administrativo por el ADMIN.
enum CerradaPor {
  SOLICITANTE
  ADMIN
}

// Solicitud de ayuda: petición formal de un SOLICITANTE para un sector concreto,
// indicando urgencia, descripción y recursos necesarios del catálogo. Nace en `ABIERTA`.
// El ADMIN la marca `ATENDIDA` o `CERRADA`; el solicitante puede cancelarla mientras
// esté abierta.
model Solicitud {
  id            String            @id @default(cuid())
  sector        String
  urgencia      UrgenciaSolicitud
  descripcion   String
  estado        EstadoSolicitud   @default(ABIERTA)
  cerradaPor    CerradaPor?
  solicitanteId String
  solicitante   Usuario           @relation(fields: [solicitanteId], references: [id])
  recursos      RecursoSolicitud[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([estado])
  @@index([sector])
  @@map("solicitudes")
}

// RecursoSolicitud: puente entre `Solicitud` y `Recurso`. `cantidadEstimada` es
// opcional (el solicitante puede no saber cuánto necesita). Se guarda como `Decimal`
// por precisión y se convierte a `number` en el límite de infraestructura.
model RecursoSolicitud {
  id                String    @id @default(cuid())
  solicitudId       String
  solicitud         Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  recursoId         String
  recurso           Recurso   @relation(fields: [recursoId], references: [id])
  cantidadEstimada  Decimal?  @db.Decimal(12, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([solicitudId, recursoId])
  @@map("recursos_solicitud")
}
