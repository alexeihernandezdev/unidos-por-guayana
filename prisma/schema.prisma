// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Rol del usuario. Controla los permisos en toda la plataforma (ver
// constitution/tech-stack.md). `SUPERADMIN` es la raíz de confianza: no se
// auto-registra, se siembra con `pnpm db:seed` y es la única autoridad que
// aprueba cuentas `ADMIN`. `ADMIN` sí es de registro público, pero la cuenta
// nace en `estadoVerificacion = PENDIENTE` y no opera hasta que el `SUPERADMIN`
// la aprueba (ver feature 015, que enmienda la 002).
enum Rol {
  SUPERADMIN
  ADMIN
  COLABORADOR
  SOLICITANTE
}

// Estado de verificación del usuario. Nace en `PENDIENTE`; su gestión real
// (aprobar/rechazar colaboradores y solicitantes) es la feature 013. Se modela
// desde ya para no re-migrar más adelante.
enum EstadoVerificacion {
  PENDIENTE
  VERIFICADO
  RECHAZADO
}

// Persona registrada en la plataforma. La contraseña se guarda siempre hasheada
// (nunca en claro). La autenticación es por credenciales (email + contraseña)
// con Auth.js v5 y sesión JWT.
model Usuario {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  nombre             String
  rol                Rol
  estadoVerificacion EstadoVerificacion @default(PENDIENTE)
  // Datos de contacto y ubicación (feature 017; ubicación por catálogo desde la
  // 020). Obligatorios en el flujo para COLABORADOR/SOLICITANTE; opcionales en
  // base para no romper cuentas creadas antes (el guard las redirige a
  // `/completar-perfil`). El ADMIN guarda sus datos en `PerfilAdmin` (016); aquí
  // solo comparte el flag WhatsApp. `estadoId`/`municipioId` referencian el
  // catálogo de ubicación (020, sustituye a los antiguos `estado`/`parroquia` de
  // texto libre).
  cedula             String?            @unique
  telefono           String?
  telefonoEsWhatsApp Boolean            @default(false)
  estadoId           String?
  estadoUbicacion    Estado?            @relation(fields: [estadoId], references: [id])
  municipioId        String?
  municipioUbicacion Municipio?         @relation(fields: [municipioId], references: [id])
  // Categorías de recurso que un COLABORADOR declara poder aportar (feature 025).
  // Capacidad de la persona (no varía por centro). Obligatoria (>= 1) para
  // COLABORADOR; la regla la asegura la aplicación (una columna array no lo hace).
  categoriasAporte   CategoriaRecurso[] @default([])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Aportes que este usuario ha registrado como colaborador (feature 006).
  aportes            Aporte[] @relation("AportesColaborador")
  aportesRegistrados Aporte[] @relation("AportesRegistrados")
  // Relación inversa: solicitudes de ayuda creadas por el solicitante (feature 007).
  solicitudes Solicitud[]
  // Relación inversa: recursos que este usuario ha propuesto al catálogo (feature 019).
  recursosPropuestos Recurso[] @relation("RecursosPropuestos")
  // Perfil ampliado de centro de acopio (solo cuentas ADMIN, feature 016). La
  // regla "solo ADMIN" la asegura la aplicación; Prisma no restringe por enum.
  perfilAdmin PerfilAdmin?
  // Puntos de acopio que gestiona este ADMIN (feature 016 declara el lado admin;
  // el modelo completo lo crea la feature 011).
  puntosAcopio PuntoAcopio[]
  // Actividades que este ADMIN creó y gestiona (feature 022; entidad renombrada
  // de `Ayuda` a `Actividad` en la feature 024).
  actividades Actividad[]
  // Afiliaciones a centros de acopio (feature 025): las que este usuario tiene
  // como COLABORADOR (`afiliaciones`) y las de su red como ADMIN (`red`).
  afiliaciones Afiliacion[] @relation("ColaboradorAfiliaciones")
  red          Afiliacion[] @relation("AdminRed")

  @@index([estadoId])
  @@index([municipioId])
  @@map("usuarios")
}

// Afiliacion (feature 025): vínculo unilateral entre un COLABORADOR y un ADMIN
// (centro de acopio) al que elige unirse. Existir la fila = afiliado; remover =
// borrar la fila (re-afiliarse permitido, sin estado de bloqueo). Puramente
// informativa: no restringe a qué Actividad puede aportar el colaborador. Se borra
// en cascada con cualquiera de los dos usuarios.
model Afiliacion {
  id            String   @id @default(cuid())
  colaboradorId String
  colaborador   Usuario  @relation("ColaboradorAfiliaciones", fields: [colaboradorId], references: [id], onDelete: Cascade)
  adminId       String
  admin         Usuario  @relation("AdminRed", fields: [adminId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([colaboradorId, adminId])
  @@index([colaboradorId])
  @@index([adminId])
  @@map("afiliaciones")
}

// Tipo de documento de identidad de un centro de acopio (feature 016). `JURIDICO`
// para organizaciones, `NATURAL` para personas. Sus valores coinciden con el enum
// de dominio para mapear sin casts.
enum TipoDocumento {
  JURIDICO
  NATURAL
}

// PerfilAdmin: extensión uno a uno de una cuenta `ADMIN` que la identifica como
// centro de acopio dentro de la red (feature 016). Se captura en el registro
// público del admin (feature 015) y el `SUPERADMIN` lo revisa al aprobar. La
// unicidad por `usuarioId` garantiza un solo perfil por cuenta. Se borra en
// cascada con el usuario.
model PerfilAdmin {
  id                 String        @id @default(cuid())
  usuarioId          String        @unique
  usuario            Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  nombreCuenta       String
  // Ubicación por catálogo (feature 020, sustituye a los antiguos `estado`/
  // `parroquia` de texto libre). Nullable en base para no bloquear la migración;
  // el flujo de registro/edición del admin los exige.
  estadoId           String?
  estadoUbicacion    Estado?       @relation(fields: [estadoId], references: [id])
  municipioId        String?
  municipioUbicacion Municipio?    @relation(fields: [municipioId], references: [id])
  telefono           String
  // Flag WhatsApp del teléfono del centro de acopio (feature 017 amplía 016).
  telefonoEsWhatsApp Boolean       @default(false)
  correo             String
  tipoDocumento      TipoDocumento
  numeroDocumento    String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([estadoId])
  @@index([municipioId])
  @@map("perfiles_admin")
}

// PuntoAcopio: ubicación física perteneciente a un `ADMIN` (feature 011). Un
// admin puede tener 0..N puntos. El punto NO declara "qué recibe": los aportes
// van a Ayudas (envíos/jornadas/eventos), no a puntos. La ubicación se captura
// como coordenadas `latitud`/`longitud` (Leaflet en la UI) más `estadoId`/
// `municipioId` del catálogo (feature 020) para filtrar y agrupar. Al crear,
// `estadoId`/`municipioId` heredan del `PerfilAdmin` como valor efectivo (se
// copian, no se referencian vivos). `referencia` es texto orientativo para el
// que va a llegar (el mapa da la posición exacta). Soft-archive con `activo`.
model PuntoAcopio {
  id                 String    @id @default(cuid())
  adminId            String
  admin              Usuario   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  nombre             String
  referencia         String
  latitud            Decimal   @db.Decimal(9, 6)
  longitud           Decimal   @db.Decimal(9, 6)
  horarios           String
  telefono           String
  telefonoEsWhatsApp Boolean   @default(true)
  correo             String?
  estadoId           String
  estadoUbicacion    Estado    @relation(fields: [estadoId], references: [id])
  municipioId        String
  municipioUbicacion Municipio @relation(fields: [municipioId], references: [id])
  activo             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Actividades que se reciben o se realizan en este punto (feature 024,
  // relación opcional). No hay cascada: al archivar/borrar un punto la actividad
  // conserva la referencia como nula (ON DELETE SET NULL).
  actividades Actividad[]

  @@unique([adminId, nombre])
  @@index([adminId])
  @@index([estadoId])
  @@index([municipioId])
  @@map("puntos_acopio")
}

// Catálogo de ubicación (feature 020). `Estado` y `Municipio` modelan la división
// político-territorial de Venezuela (24 entidades federales y ~335 municipios) y
// se siembran con `pnpm db:seed`. `codigo` es la clave natural estable (ISO
// 3166-2:VE para el estado, `<codigoEstado>-<nn>` para el municipio) que hace la
// siembra idempotente (upsert por `codigo`). Es de solo lectura para la app: no
// hay CRUD; se mantiene vía seed. `Usuario` y `PerfilAdmin` referencian este
// catálogo por `estadoId`/`municipioId` en vez de guardar texto libre.
model Estado {
  id     String @id @default(cuid())
  codigo String @unique
  nombre String
  // Coordenadas de la capital del estado (feature 011): centro inicial del mapa
  // al crear un punto de acopio. Nullable en base (el seed las llena; upsert por
  // `codigo`); el consumidor cae a un centro por defecto de Venezuela si faltan.
  latitudCapital  Decimal? @db.Decimal(9, 6)
  longitudCapital Decimal? @db.Decimal(9, 6)

  municipios    Municipio[]
  usuarios      Usuario[]
  perfilesAdmin PerfilAdmin[]
  puntosAcopio  PuntoAcopio[]

  @@map("estados")
}

// Municipio del catálogo. Cuelga de un `Estado` (relación obligatoria); el
// desplegable de municipio se filtra por el `estadoId` elegido. `codigo` único
// global permite corregir nombres sin romper las FKs que lo referencian.
model Municipio {
  id       String @id @default(cuid())
  codigo   String @unique
  nombre   String
  estadoId String
  estado   Estado @relation(fields: [estadoId], references: [id], onDelete: Cascade)

  usuarios      Usuario[]
  perfilesAdmin PerfilAdmin[]
  puntosAcopio  PuntoAcopio[]

  @@index([estadoId])
  @@map("municipios")
}

// Categoría de un recurso del catálogo (ver feature 004 y constitution/tech-stack.md).
// `SUMINISTRO` (agua, alimentos, medicinas…), `TRANSPORTE` (camión, combustible…),
// `PERSONAL` (voluntarios…) y `MONETARIO` (donación en USD/Bs, recibida por fuera
// de la app). Sus valores coinciden con el enum de dominio para mapear sin casts.
enum CategoriaRecurso {
  SUMINISTRO
  TRANSPORTE
  PERSONAL
  MONETARIO
}

// Estado de aprobación del recurso (feature 019). Un `ADMIN` crea recursos ya
// `APROBADO`; un `SOLICITANTE` puede proponer nuevos recursos que nacen
// `PROPUESTO` a la espera de revisión. Solo los `APROBADO` (y `activo`) son
// seleccionables en metas y aportes. `RECHAZADO` es terminal y se conserva
// para auditoría. Backfill: los recursos existentes quedan `APROBADO`.
enum EstadoAprobacionRecurso {
  APROBADO
  PROPUESTO
  RECHAZADO
}

// Recurso del catálogo: la referencia estable contra la que se miden metas y
// aportes. `nombre` es único (se guarda tal cual con trim; la unicidad insensible
// a mayúsculas se valida en la aplicación). `unidad` es texto libre (litros, cajas,
// personas, USD…). No se borran: se archivan (`activo = false`) para no dejar metas
// ni aportes huérfanos (features 005/006).
model Recurso {
  id               String                  @id @default(cuid())
  nombre           String                  @unique
  unidad           String
  categoria        CategoriaRecurso
  descripcion      String?
  activo           Boolean                 @default(true)
  estadoAprobacion EstadoAprobacionRecurso @default(APROBADO)
  propuestoPorId   String?
  propuestoPor     Usuario?                @relation("RecursosPropuestos", fields: [propuestoPorId], references: [id])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // Relación inversa: metas de envío que apuntan a este recurso (feature 005).
  // Como los recursos se archivan (no se borran), no habrá metas huérfanas.
  metas MetaRecurso[]

  // Aportes registrados contra este recurso (feature 006).
  aportes Aporte[]
  // Relación inversa: recursos necesarios en solicitudes de ayuda (feature 007).
  recursoSolicitudes RecursoSolicitud[]

  @@index([estadoAprobacion])
  @@map("recursos")
}

// Tipo de actividad (feature 018). La entidad Actividad es la misma para las tres
// clases (envío / jornada / evento social): comparten metas, aportes y seguimiento.
// Cambia el vocabulario visible en la UI y, desde la feature 024, la secuencia de
// estados válida (ver `EstadoActividad`). Backfill: las actividades existentes se
// consideran `ENVIO`.
enum TipoActividad {
  ENVIO
  JORNADA
  EVENTO_SOCIAL
}

// Ciclo de vida de una Actividad (features 005 y 024). Un único enum en base con la
// unión de los estados de las dos secuencias; qué transiciones son válidas lo module
// el dominio según el `tipo` (regla pura, `maquinaEstados.ts`):
//   ENVIO:               RECOLECTANDO → LISTO → EN_TRANSITO → ENTREGADO
//   JORNADA/EVENTO_SOCIAL: RECOLECTANDO → LISTA → EN_CURSO → REALIZADA
// `RECOLECTANDO` es el estado inicial compartido. Sus valores coinciden con los del
// dominio para mapear sin casts.
enum EstadoActividad {
  RECOLECTANDO
  LISTO
  EN_TRANSITO
  ENTREGADO
  LISTA
  EN_CURSO
  REALIZADA
}

// Actividad (antes `Ayuda`, renombrada en la feature 024): la entidad central de la
// plataforma. Según su `tipo` es un envío de ayuda humanitaria, una jornada o un
// evento social hacia un sector, con una fecha de inicio y un ciclo de vida. Define
// qué necesita y cuánto mediante sus `metas` (MetaRecurso). Solo la gestiona el
// `ADMIN`. Nace en `RECOLECTANDO`; la cabecera y las metas solo se editan mientras
// siga en ese estado (después quedan congeladas para medir el progreso).
model Actividad {
  id            String          @id @default(cuid())
  // Dueño: el ADMIN que creó la actividad (feature 022). Inmutable tras el alta.
  adminId       String
  admin         Usuario         @relation(fields: [adminId], references: [id])
  titulo        String
  sectorDestino String
  // `fecha` es el inicio; `horaFin` (feature 024) es el fin opcional de una JORNADA
  // o EVENTO_SOCIAL (p. ej. "de 9:00 a 13:00"). Un ENVIO no la usa.
  fecha         DateTime
  horaFin       DateTime?
  estado        EstadoActividad @default(RECOLECTANDO)
  tipo          TipoActividad   @default(ENVIO)
  descripcion   String?
  // Punto de acopio opcional del mismo ADMIN dueño (feature 024): dónde se recibe el
  // aporte o dónde ocurre la jornada/evento. Nullable; ON DELETE SET NULL para no
  // perder la actividad si el punto se elimina.
  puntoAcopioId String?
  puntoAcopio   PuntoAcopio?    @relation(fields: [puntoAcopioId], references: [id], onDelete: SetNull)
  metas         MetaRecurso[]
  aportes       Aporte[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([adminId])
  @@index([tipo])
  @@index([estado])
  @@index([fecha])
  @@index([puntoAcopioId])
  @@map("actividades")
}

// MetaRecurso: puente entre `Actividad` y `Recurso`. `cantidadObjetivo` es cuánto
// necesita la actividad de ese recurso, en la unidad del recurso. Se guarda como
// `Decimal` por precisión y se convierte a `number` en el límite de infraestructura
// (el dominio trabaja con números puros). Única por (actividad, recurso): un recurso
// no se repite en dos metas de la misma Actividad. Se borra en cascada con su Actividad.
model MetaRecurso {
  id               String    @id @default(cuid())
  actividadId      String
  actividad        Actividad @relation(fields: [actividadId], references: [id], onDelete: Cascade)
  recursoId        String
  recurso          Recurso   @relation(fields: [recursoId], references: [id])
  cantidadObjetivo Decimal   @db.Decimal(12, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([actividadId, recursoId])
  @@map("metas_recurso")
}

// Estado del Aporte (feature 006). `COMPROMETIDO` es la intención declarada por el
// colaborador; solo cuando el ADMIN lo marca `RECIBIDO` suma al progreso de la meta.
// Sus valores coinciden con el enum de dominio para mapear sin casts.
enum TipoMedioDonacion {
  CUENTA_BANCARIA
  PAGO_MOVIL
  PAYPAL
  ZELLE
  BINANCE
  EFECTIVO
  OTRO
}

model MedioDonacion {
  id        String            @id @default(cuid())
  tipo      TipoMedioDonacion
  titular   String
  moneda    String
  datos     String
  nota      String?
  orden     Int               @default(0)
  activo    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  aportes   Aporte[]

  @@index([activo, orden])
  @@map("medios_donacion")
}

enum EstadoAporte {
  COMPROMETIDO
  RECIBIDO
}

// Aporte: registro con el que un COLABORADOR ofrece ayuda a una Actividad concreta
// contra un Recurso del catálogo. Nace en `COMPROMETIDO`; el ADMIN lo marca
// `RECIBIDO` al confirmar la entrega (o el ingreso monetario externo). Solo los
// `RECIBIDO` suman al progreso de la meta correspondiente (feature 009).
// No se hace cascade desde Actividad: una Actividad con aportes no debería borrarse
// (solo se elimina en `RECOLECTANDO`, y quitar los aportes ahí es explícito).
model Aporte {
  id             String       @id @default(cuid())
  actividadId    String?
  actividad      Actividad?   @relation(fields: [actividadId], references: [id])
  recursoId      String
  recurso        Recurso      @relation(fields: [recursoId], references: [id])
  colaboradorId  String?
  colaborador    Usuario?     @relation("AportesColaborador", fields: [colaboradorId], references: [id])
  registradoPorId String?
  registradoPor   Usuario?       @relation("AportesRegistrados", fields: [registradoPorId], references: [id])
  medioDonacionId String?
  medioDonacion   MedioDonacion? @relation(fields: [medioDonacionId], references: [id])
  cantidad       Decimal      @db.Decimal(12, 2)
  moneda         String?
  estado         EstadoAporte @default(COMPROMETIDO)
  nota           String?
  referencia     String?
  recibidoEn     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([actividadId])
  @@index([actividadId, recursoId, estado])
  @@index([medioDonacionId])
  @@map("aportes")
}
// Urgencia de una solicitud de ayuda (feature 007). Tres niveles para priorizar sin
// paralizar al solicitante con una escala numérica.
enum UrgenciaSolicitud {
  BAJA
  MEDIA
  ALTA
}

// Ciclo de vida de una solicitud de ayuda (feature 007). Avanza desde `ABIERTA` hacia
// `ATENDIDA` o `CERRADA`; ambos son terminales y no se reabren.
enum EstadoSolicitud {
  ABIERTA
  ATENDIDA
  CERRADA
}

// Quién cerró la solicitud (feature 007). Distingue cancelación del solicitante de
// cierre administrativo por el ADMIN.
enum CerradaPor {
  SOLICITANTE
  ADMIN
}

// Solicitud de ayuda: petición formal de un SOLICITANTE para un sector concreto,
// indicando urgencia, descripción y recursos necesarios del catálogo. Nace en `ABIERTA`.
// El ADMIN la marca `ATENDIDA` o `CERRADA`; el solicitante puede cancelarla mientras
// esté abierta.
model Solicitud {
  id            String            @id @default(cuid())
  sector        String
  urgencia      UrgenciaSolicitud
  descripcion   String
  estado        EstadoSolicitud   @default(ABIERTA)
  cerradaPor    CerradaPor?
  solicitanteId String
  solicitante   Usuario           @relation(fields: [solicitanteId], references: [id])
  recursos      RecursoSolicitud[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([estado])
  @@index([sector])
  @@map("solicitudes")
}

// RecursoSolicitud: puente entre `Solicitud` y `Recurso`. `cantidadEstimada` es
// opcional (el solicitante puede no saber cuánto necesita). Se guarda como `Decimal`
// por precisión y se convierte a `number` en el límite de infraestructura.
model RecursoSolicitud {
  id                String    @id @default(cuid())
  solicitudId       String
  solicitud         Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  recursoId         String
  recurso           Recurso   @relation(fields: [recursoId], references: [id])
  cantidadEstimada  Decimal?  @db.Decimal(12, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([solicitudId, recursoId])
  @@map("recursos_solicitud")
}
