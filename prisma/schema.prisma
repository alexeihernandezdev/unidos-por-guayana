// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Rol del usuario. Controla los permisos en toda la plataforma (ver
// constitution/tech-stack.md). `ADMIN` no es auto-registrable: se crea por seed
// o lo promueve otro `ADMIN` (ver feature 002).
enum Rol {
  ADMIN
  COLABORADOR
  SOLICITANTE
}

// Estado de verificaciรณn del usuario. Nace en `PENDIENTE`; su gestiรณn real
// (aprobar/rechazar colaboradores y solicitantes) es la feature 013. Se modela
// desde ya para no re-migrar mรกs adelante.
enum EstadoVerificacion {
  PENDIENTE
  VERIFICADO
  RECHAZADO
}

// Persona registrada en la plataforma. La contraseรฑa se guarda siempre hasheada
// (nunca en claro). La autenticaciรณn es por credenciales (email + contraseรฑa)
// con Auth.js v5 y sesiรณn JWT.
model Usuario {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  nombre             String
  rol                Rol
  estadoVerificacion EstadoVerificacion @default(PENDIENTE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Aportes que este usuario ha registrado como colaborador (feature 006).
  aportes Aporte[]
  // Relaciรณn inversa: solicitudes de ayuda creadas por el solicitante (feature 007).
  solicitudes Solicitud[]

  @@map("usuarios")
}

// Categorรญa de un recurso del catรกlogo (ver feature 004 y constitution/tech-stack.md).
// `SUMINISTRO` (agua, alimentos, medicinasโฆ), `TRANSPORTE` (camiรณn, combustibleโฆ),
// `PERSONAL` (voluntariosโฆ) y `MONETARIO` (donaciรณn en USD/Bs, recibida por fuera
// de la app). Sus valores coinciden con el enum de dominio para mapear sin casts.
enum CategoriaRecurso {
  SUMINISTRO
  TRANSPORTE
  PERSONAL
  MONETARIO
}

// Recurso del catรกlogo: la referencia estable contra la que se miden metas y
// aportes. `nombre` es รบnico (se guarda tal cual con trim; la unicidad insensible
// a mayรบsculas se valida en la aplicaciรณn). `unidad` es texto libre (litros, cajas,
// personas, USDโฆ). No se borran: se archivan (`activo = false`) para no dejar metas
// ni aportes huรฉrfanos (features 005/006).
model Recurso {
  id          String           @id @default(cuid())
  nombre      String           @unique
  unidad      String
  categoria   CategoriaRecurso
  descripcion String?
  activo      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relaciรณn inversa: metas de envรญo que apuntan a este recurso (feature 005).
  // Como los recursos se archivan (no se borran), no habrรก metas huรฉrfanas.
  metas MetaRecurso[]

  // Aportes registrados contra este recurso (feature 006).
  aportes Aporte[]
  // Relaciรณn inversa: recursos necesarios en solicitudes de ayuda (feature 007).
  recursoSolicitudes RecursoSolicitud[]

  @@map("recursos")
}

// Ciclo de vida de una Ayuda (ver feature 005 y constitution/tech-stack.md). Avanza
// en un solo sentido: RECOLECTANDO โ LISTO โ EN_TRANSITO โ ENTREGADO. La mรกquina de
// estados (transiciones vรกlidas) vive como regla pura en el dominio. Sus valores
// coinciden con el enum de dominio para mapear sin casts.
enum EstadoAyuda {
  RECOLECTANDO
  LISTO
  EN_TRANSITO
  ENTREGADO
}

// Ayuda / Envรญo: la entidad central de la plataforma. Un envรญo concreto de ayuda
// humanitaria hacia un sector, con una fecha de salida y un ciclo de vida. Define
// quรฉ necesita y cuรกnto mediante sus `metas` (MetaRecurso). Solo la gestiona el
// `ADMIN`. Nace en `RECOLECTANDO`; la cabecera y las metas solo se editan mientras
// siga en ese estado (despuรฉs quedan congeladas para medir el progreso).
model Ayuda {
  id           String        @id @default(cuid())
  titulo       String
  sectorDestino String
  fecha        DateTime
  estado       EstadoAyuda   @default(RECOLECTANDO)
  descripcion  String?
  metas        MetaRecurso[]
  aportes      Aporte[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("ayudas")
}

// MetaRecurso: puente entre `Ayuda` y `Recurso`. `cantidadObjetivo` es cuรกnto
// necesita el envรญo de ese recurso, en la unidad del recurso. Se guarda como
// `Decimal` por precisiรณn y se convierte a `number` en el lรญmite de infraestructura
// (el dominio trabaja con nรบmeros puros). รnica por (ayuda, recurso): un recurso no
// se repite en dos metas de la misma Ayuda. Se borra en cascada con su Ayuda.
model MetaRecurso {
  id               String   @id @default(cuid())
  ayudaId          String
  ayuda            Ayuda    @relation(fields: [ayudaId], references: [id], onDelete: Cascade)
  recursoId        String
  recurso          Recurso  @relation(fields: [recursoId], references: [id])
  cantidadObjetivo Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([ayudaId, recursoId])
  @@map("metas_recurso")
}

// Estado del Aporte (feature 006). `COMPROMETIDO` es la intenciรณn declarada por el
// colaborador; solo cuando el ADMIN lo marca `RECIBIDO` suma al progreso de la meta.
// Sus valores coinciden con el enum de dominio para mapear sin casts.
enum EstadoAporte {
  COMPROMETIDO
  RECIBIDO
}

// Aporte: registro con el que un COLABORADOR ofrece ayuda a una Ayuda concreta
// contra un Recurso del catรกlogo. Nace en `COMPROMETIDO`; el ADMIN lo marca
// `RECIBIDO` al confirmar la entrega (o el ingreso monetario externo). Solo los
// `RECIBIDO` suman al progreso de la meta correspondiente (feature 009).
// No se hace cascade desde Ayuda: una Ayuda con aportes no deberรญa borrarse (solo
// se elimina en `RECOLECTANDO`, y quitar los aportes en ese punto es explรญcito).
model Aporte {
  id             String       @id @default(cuid())
  ayudaId        String
  ayuda          Ayuda        @relation(fields: [ayudaId], references: [id])
  recursoId      String
  recurso        Recurso      @relation(fields: [recursoId], references: [id])
  colaboradorId  String
  colaborador    Usuario      @relation(fields: [colaboradorId], references: [id])
  cantidad       Decimal      @db.Decimal(12, 2)
  estado         EstadoAporte @default(COMPROMETIDO)
  nota           String?
  recibidoEn     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([ayudaId])
  @@index([ayudaId, recursoId, estado])
  @@map("aportes")
}
// Urgencia de una solicitud de ayuda (feature 007). Tres niveles para priorizar sin
// paralizar al solicitante con una escala numรฉrica.
enum UrgenciaSolicitud {
  BAJA
  MEDIA
  ALTA
}

// Ciclo de vida de una solicitud de ayuda (feature 007). Avanza desde `ABIERTA` hacia
// `ATENDIDA` o `CERRADA`; ambos son terminales y no se reabren.
enum EstadoSolicitud {
  ABIERTA
  ATENDIDA
  CERRADA
}

// Quiรฉn cerrรณ la solicitud (feature 007). Distingue cancelaciรณn del solicitante de
// cierre administrativo por el ADMIN.
enum CerradaPor {
  SOLICITANTE
  ADMIN
}

// Solicitud de ayuda: peticiรณn formal de un SOLICITANTE para un sector concreto,
// indicando urgencia, descripciรณn y recursos necesarios del catรกlogo. Nace en `ABIERTA`.
// El ADMIN la marca `ATENDIDA` o `CERRADA`; el solicitante puede cancelarla mientras
// estรฉ abierta.
model Solicitud {
  id            String            @id @default(cuid())
  sector        String
  urgencia      UrgenciaSolicitud
  descripcion   String
  estado        EstadoSolicitud   @default(ABIERTA)
  cerradaPor    CerradaPor?
  solicitanteId String
  solicitante   Usuario           @relation(fields: [solicitanteId], references: [id])
  recursos      RecursoSolicitud[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([estado])
  @@index([sector])
  @@map("solicitudes")
}

// RecursoSolicitud: puente entre `Solicitud` y `Recurso`. `cantidadEstimada` es
// opcional (el solicitante puede no saber cuรกnto necesita). Se guarda como `Decimal`
// por precisiรณn y se convierte a `number` en el lรญmite de infraestructura.
model RecursoSolicitud {
  id                String    @id @default(cuid())
  solicitudId       String
  solicitud         Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  recursoId         String
  recurso           Recurso   @relation(fields: [recursoId], references: [id])
  cantidadEstimada  Decimal?  @db.Decimal(12, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([solicitudId, recursoId])
  @@map("recursos_solicitud")
}
